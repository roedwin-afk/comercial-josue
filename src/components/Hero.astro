---
import { siteConfig, whatsappLink } from "../config/site.ts";

const { hero } = siteConfig;
---

<section class="hero">
    <div class="container">
        <div class="hero-content">
            <span class="eyebrow">{hero.eyebrow}</span>
            <h1>
                {hero.tituloAntes}
                <span class="highlight">{hero.tituloAcento}</span>
                {hero.tituloDespues}
            </h1>
            <p>{hero.parrafo}</p>
            <div class="hero-ctas">
                <a
                    href={whatsappLink(hero.mensajeWhatsapp)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-primary"
                >
