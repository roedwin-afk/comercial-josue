---
import { siteConfig } from "../config/site.ts";
import PriceTagCard from "./PriceTagCard.astro";

const { about, tarjetas } = siteConfig;
---

<section class="about-section section-padding" id="nosotros">
  <div class="container">
    <div class="about-intro">
      <span class="eyebrow eyebrow-green">{about.eyebrow}</span>
      <h2>{about.titulo}</h2>
      <p>{about.parrafo}</p>
    </div>

    <div class="cards-grid">
      {tarjetas.map((tarjeta) => (
        <PriceTagCard tarjeta={tarjeta} />
      ))}
    </div>
  </div>
</section>

<style>
  .about-section {
    background-color: var(--paper);
  }

  .about-intro {
    max-width: 650px;
  }

  .eyebrow-green {
    color: var(--green);
  }

  .about-intro h2 {
    font-size: clamp(2.2rem, 4vw, 3rem);
    margin-bottom: 1.5rem;
    color: var(--ink);
  }

  .about-intro p {
    font-size: 1.1rem;
    color: rgba(28, 25, 23, 0.8);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
    margin-top: 3.5rem;
  }
</style>