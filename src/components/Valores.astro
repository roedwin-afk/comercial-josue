---
import { siteConfig } from "../config/site.ts";

const { valores } = siteConfig;
---

<section class="values-band section-padding" id="valores">
  <div class="container">
    <span class="eyebrow">{valores.eyebrow}</span>
    <h2>{valores.titulo}</h2>
    <p>{valores.parrafo}</p>

    <div class="values-grid">
      {valores.chips.map((chip) => (
        <span class="value-chip">{chip}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .values-band {
    background-color: var(--ink);
    color: var(--white);
    text-align: center;
    position: relative;
  }

  .values-band::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--red) 0%, var(--gold) 50%, var(--green) 100%);
  }

  .values-band h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .values-band p {
    color: rgba(246, 239, 228, 0.7);
    max-width: 600px;
    margin: 0 auto 2rem auto;
  }

  .values-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .value-chip {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.8rem 1.8rem;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    color: var(--paper);
    transition: all 0.3s ease;
  }

  .value-chip:hover {
    border-color: var(--gold);
    color: var(--gold);
    transform: scale(1.05);
    background-color: rgba(214, 168, 74, 0.05);
  }
</style>