---
import { siteConfig, mapEmbedSrc, infoItems } from "../config/site.ts";
import type { InfoItem } from "../config/site.ts";

const { ubicacion } = siteConfig;
const items: InfoItem[] = infoItems();

// Paths SVG por tipo de info-item (mismos íconos del diseño original)
const iconPaths: Record<InfoItem["tipo"], string> = {
  ubicacion:
    '<path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/><circle cx="12" cy="10" r="3"/>',
  email:
    '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  whatsapp:
    '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
};
---

<section class="location-section section-padding" id="ubicacion">
  <div class="container">
    <div class="location-heading">
      <span class="eyebrow eyebrow-green">{ubicacion.eyebrow}</span>
      <h2>{ubicacion.titulo}</h2>
    </div>

    <div class="location-grid">
      <div class="contact-info">
        <div class="info-card">
          {items.map((item) => (
            <div class="info-item">
              <div class="info-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  set:html={iconPaths[item.tipo]}
                />
              </div>
              <div class="info-text">
                <h4>{item.label}</h4>
                {item.href ? (
                  <p><a href={item.href} target="_blank" rel="noopener noreferrer">{item.valor}</a></p>
                ) : (
                  <p>{item.valor}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <div class="mayoreo-note">
          <p>{ubicacion.notaMayoreo}</p>
        </div>
      </div>

      <div class="map-wrapper">
        <iframe
          src={mapEmbedSrc()}
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Ubicación interactiva de ${siteConfig.nombre}`}
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .location-section {
    background-color: var(--paper);
    border-top: 1px solid rgba(28, 25, 23, 0.08);
  }

  .location-heading {
    margin-bottom: 3.5rem;
  }

  .eyebrow-green {
    color: var(--green);
  }

  .location-heading h2 {
    font-size: clamp(2.2rem, 4vw, 3rem);
    color: var(--ink);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .location-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-card {
    background-color: var(--white);
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid rgba(28, 25, 23, 0.08);
    box-shadow: 0 4px 12px rgba(28, 25, 23, 0.02);
  }

  .info-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-icon {
    color: var(--red);
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .info-text h4 {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
  }

  .info-text p,
  .info-text a {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
  }

  .info-text a:hover {
    text-decoration: underline;
    color: var(--red);
  }

  .mayoreo-note {
    padding: 0 1rem;
  }

  .mayoreo-note p {
    font-size: 0.95rem;
    color: rgba(28, 25, 23, 0.7);
    font-style: italic;
  }

  .map-wrapper {
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 12px;
    overflow: hidden;
    border: 3px solid var(--white);
    box-shadow: 0 10px 30px rgba(28, 25, 23, 0.08);
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 768px) {
    .map-wrapper {
      height: 350px;
    }
  }
</style>